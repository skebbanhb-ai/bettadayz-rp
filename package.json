{
  "name": "bettadayz-rp-bettabukz-edition",
  "version": "1.5.0-bettabukz",
  "private": true,
  "main": "server/server.js",
  "scripts": {
    "local": "node server/server.js",
    "start": "node server/server.js",
    "build": "node -e \"console.log('Static web assets ready for Capacitor sync.')\"",
    "pc": "electron desktop/main.js",
    "desktop": "electron desktop/main.js",
    "pc:build": "electron-builder --win nsis portable",
    "build:win": "electron-builder --win nsis portable",
    "sprite:build": "node tools/build-sprite-atlas.js",
    "test": "node --test tests/*.test.js",
    "ship:check": "npm run sprite:build && npm test",
    "mobile:add:android": "npm install @capacitor/android && npx cap add android",
    "mobile:add:ios": "npm install @capacitor/ios && npx cap add ios",
    "mobile:sync": "npx cap sync",
    "android:studio": "npx cap open android",
    "ios:xcode": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.bettadayz.rp",
    "productName": "BettaDayz RP",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "server/**/*",
      "public/**/*",
      "data/**/*",
      "package.json",
      ".env.example"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
